{
  "name": "shipline",
  "version": "0.1.0",
  "description": "Detect accidental public API changes in JavaScript and TypeScript packages before release.",
  "homepage": "https://github.com/Hooptop/Shipline#readme",
  "bugs": {
    "url": "https://github.com/Hooptop/Shipline/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hooptop/Shipline.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "shipline": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run build && bun run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "shipline": "node dist/cli.js",
    "snapshot:self": "node dist/cli.js snapshot --entry package.json --out api-snapshot.json",
    "prepack": "bun run build"
  },
  "keywords": [
    "api",
    "typescript",
    "semver",
    "maintainer",
    "github-actions",
    "release",
    "pull-request",
    "changelog"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "globals": "^16.4.0",
    "prettier": "^3.7.4",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.8"
  }
}
